pipeline {

    agent any

    tools {
        jdk 'JDK21'
        maven 'Maven3'
    }

    parameters {

        choice(
            name: 'ENVIRONMENT',
            choices: [
                'dev',
                'stage',
                'prod',
                'customer-a',
                'customer-b',
                'customer-c',
                'customer-d',
                'customer-e',
                'customer-f',
                'customer-g'
            ],
            description: 'Select Deployment Environment'
        )

        string(
            name: 'IMAGE_TAG',
            defaultValue: 'v1',
            description: 'Docker Image Tag'
        )

        string(
            name: 'NAMESPACE',
            defaultValue: 'enterprise-devops',
            description: 'Kubernetes Namespace'
        )

        string(
            name: 'REPLICAS',
            defaultValue: '2',
            description: 'Number of Application Replicas'
        )
    }

    environment {
        APP_NAME = "analytics-platform"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build Application') {
            steps {
                dir('analytics-platform') {
                    sh 'mvn clean package -DskipTests'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir('analytics-platform') {
                    withSonarQubeEnv('SonarQube') {
                        sh '''
                        mvn sonar:sonar \
                          -Dsonar.projectKey=enterprise-product-deployment \
                          -Dsonar.projectName=enterprise-product-deployment
                        '''
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('analytics-platform') {
                    sh """
                    docker build -t ${APP_NAME}:${params.IMAGE_TAG} .
                    """
                }
            }
        }

        stage('Verify Docker Image') {
            steps {
                sh 'docker images'
            }
        }

        stage('Deployment Details') {
            steps {
                echo "======================================"
                echo "Environment : ${params.ENVIRONMENT}"
                echo "Namespace   : ${params.NAMESPACE}"
                echo "Image Tag   : ${params.IMAGE_TAG}"
                echo "Replicas    : ${params.REPLICAS}"
                echo "======================================"
            }
        }

        stage('Deploy to Kubernetes') {

            steps {

                sh """
                kubectl config set-context --current --namespace=${params.NAMESPACE}

                kubectl apply -f ../product-kubernetes/configmap.yaml
                kubectl apply -f ../product-kubernetes/secrets.yaml
                kubectl apply -f ../product-kubernetes/deployment.yaml
                kubectl apply -f ../product-kubernetes/service.yaml
                kubectl apply -f ../product-kubernetes/ingress.yaml
                """
            }
        }

        stage('Verify Deployment') {

            steps {

                sh """
                kubectl get pods -n ${params.NAMESPACE}
                kubectl get svc -n ${params.NAMESPACE}
                kubectl get deployment -n ${params.NAMESPACE}
                """
            }
        }
    }

    post {
        success {

            echo "======================================"
            echo "Deployment Successful"
            echo "Environment : ${params.ENVIRONMENT}"
            echo "======================================"

        }

        failure {

            echo "======================================"
            echo "Deployment Failed"
            echo "======================================"

        }
<<<<<<< HEAD

        always {

            cleanWs()

        }
